{
  "build": {
    "arduino": {
      "ldscript": "esp32h2_out.ld"
    },
    "core": "esp32",
    "extra_flags": "-DARDUINO_ESP32H2_DEV -DARDUINO_USB_MODE=1 -DARDUINO_USB_CDC_ON_BOOT=1",
    "f_cpu": "96000000L",
    "f_flash": "48000000L",
    "flash_mode": "qio",
    "mcu": "esp32h2",
    "variant": "esp32h2"
  },
  "connectivity": [
    "bluetooth",
    "zigbee",
    "thread"
  ],
  "debug": {
    "openocd_target": "esp32h2.cfg"
  },
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "name": "Espressif ESP32-H2-DevKitM-1",
  "upload": {
    "flash_size": "4MB",
    "maximum_ram_size": 327680,
    "maximum_size": 2097152,
    "require_upload_port": true,
    "speed": 921600
  },
  "url": "https://docs.espressif.com/projects/espressif-esp-dev-kits/en/latest/esp32h2/esp32-h2-devkitm-1/user_guide.html",
  "vendor": "Espressif"
}